# Frontend Environment Variables
VITE_API_URL=http://localhost:5000/api

# Google OAuth Client ID (get from https://console.cloud.google.com/)
# Create credentials > OAuth client ID > Web application
# Add authorized JavaScript origins: http://localhost:8080
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Backend Environment Variables (create in backend/.env)
# PORT=5000
# MONGODB_URI=mongodb://localhost:27017/finance-flow
# JWT_SECRET=your-secret-key
# NODE_ENV=development
# GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
